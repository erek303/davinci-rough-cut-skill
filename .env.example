# DaVinci Rough Cut 环境变量示例 / Environment variables example
#
# 使用方法：
# 1. 复制本文件为本地 .env：cp .env.example .env
# 2. 把 your-... 占位符替换成你自己的真实 key。
# 3. 真实 .env 不要提交到 GitHub，也不要发给 Agent 聊天窗口。
# 4. 脚本不会自动读取 .env；如需临时加载，执行：
#    set -a; source .env; set +a
#
# 说明：环境变量名必须保持英文，等号右边才是你需要填写的值。


# ── A. ASR 转录：火山引擎极速版（推荐默认） ─────────────────────
# 用途：把长素材音频识别成带时间码的 transcript.json。
# 推荐使用火山「录音文件识别极速版 / 大模型录音文件极速版识别 API」。
# 这条路径直接上传本地音频数据，不需要先创建 TOS bucket。
# English: recommended default ASR path; local audio data is sent directly.
VOLCENGINE_API_KEY=your-volcengine-api-key

# 旧版控制台可能给的是 App ID + Access Token。
# English: legacy auth only if your console provides App ID + Access Token.
# VOLCENGINE_APP_ID=your-volcengine-app-id
# VOLCENGINE_ACCESS_TOKEN=your-volcengine-access-token

# 可选：默认就是 fast。只有你明确要走旧 URL/TOS 模式时才改。
# English: optional; default is fast.
# VOLCENGINE_ASR_MODE=fast


# ── A-advanced. 火山旧 URL/TOS 模式（普通用户先不用看） ────────────
# 用途：只有当你明确设置 VOLCENGINE_ASR_MODE=standard-url 时才需要。
# 普通用户不需要先开 TOS，也不需要创建私有 bucket。
# English: advanced legacy URL mode only.
# VOLCENGINE_ASR_MODE=standard-url
# VOLCENGINE_ACCESS_KEY=your-volcengine-iam-access-key
# VOLCENGINE_SECRET_KEY=your-volcengine-iam-secret-key
# VOLCENGINE_TOS_BUCKET=your-tos-bucket
# VOLCENGINE_TOS_REGION=cn-shanghai
# VOLCENGINE_TOS_ENDPOINT=tos-cn-shanghai.volces.com


# ── B. 大模型：内容留删判断（任选一个） ─────────────────────────
# 用途：读取 transcript.json，判断每句话 keep/delete，并写入 edited.json。
# 至少配置下面任意一个模型服务。
# English: choose at least one LLM backend.

# 可选：强制指定优先使用哪个后端。可选值：glm / deepseek / mimo / anthropic
# English: optional, force one provider.
# AI_EDIT_BACKEND=deepseek

# 智谱 GLM
GLM_API_KEY=your-glm-api-key
# GLM_MODEL=glm-4.7

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash

# 小米 MiMo
MIMO_API_KEY=your-xiaomi-mimo-api-key
# 兼容写法：如果你习惯叫 XIAOMI_API_KEY，也可以用下面这个。
# XIAOMI_API_KEY=your-xiaomi-mimo-api-key
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# MIMO_MODEL=mimo-v2.5-pro

# Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022


# ── C. 小米 MiMo ASR：短音频转录备选 ───────────────────────────
# 用途：只建议测试短音频；长素材粗剪仍建议走火山 ASR 极速版。
# 原因：MiMo ASR 请求是 wav/mp3 base64，payload 上限约 10MB。
# English: short-audio fallback only.
# MIMO_ASR_MODEL=mimo-v2.5-asr
